{
    "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!node_modules",
            "!stuff",
            "!public",
            "!coverage",
            "!src/js/scripts.babel.generated.js",
            "!api/openapi/openapi-dist.json"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "bracketSpacing": true,
        "lineEnding": "lf",
        "useEditorconfig": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedFunctionParameters": "off",
                "noUnusedVariables": "error",
                "noUnreachable": "error"
            },
            "suspicious": {
                "noExplicitAny": "error",
                "noConsole": {
                    "level": "warn",
                    "options": {
                        "allow": ["error", "warn"]
                    }
                }
            },
            "style": {
                "recommended": true,
                "useConst": "error",
                "useBlockStatements": "error",
                "noParameterAssign": "warn",
                "noNestedTernary": "warn",
                "noImplicitBoolean": "warn"
            },
            "a11y": {
                "recommended": true
            },
            "complexity": {
                "recommended": true,
                "noExcessiveCognitiveComplexity": {
                    "level": "warn",
                    "options": {
                        "maxAllowedComplexity": 18
                    }
                }
            },
            "performance": {
                "recommended": true
            },
            "security": {
                "recommended": true
            }
        }
    },
    "overrides": [
        {
            "includes": ["**/*.test.js"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    }
                }
            }
        }
    ],
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "javascript": {
        "formatter": {
            "enabled": true,
            "quoteStyle": "single",
            "trailingCommas": "none",
            "arrowParentheses": "always",
            "semicolons": "always",
            "indentStyle": "space",
            "indentWidth": 4,
            "lineWidth": 100,
            "quoteProperties": "asNeeded"
        }
    },
    "json": {
        "formatter": {
            "enabled": true,
            "trailingCommas": "none",
            "indentStyle": "space",
            "indentWidth": 4,
            "lineWidth": 100
        }
    },
    "css": {
        "formatter": {
            "enabled": true,
            "indentStyle": "space",
            "indentWidth": 4,
            "lineWidth": 100
        },
        "parser": {
            "cssModules": false
        }
    }
}
