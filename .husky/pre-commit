STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

npm run precommit

# Re-stage only files that were already staged before running the hook.
if [ -n "$STAGED_FILES" ]; then
	printf '%s\n' "$STAGED_FILES" | while IFS= read -r file; do
		if [ -e "$file" ]; then
			git add -- "$file"
		fi
	done
fi

# Keep generated artifacts in sync when hook checks update them.
for generated in public/stylesheets/all.css api/openapi/openapi-dist.json; do
	if git ls-files --error-unmatch "$generated" >/dev/null 2>&1; then
		if ! git diff --quiet -- "$generated"; then
			git add -- "$generated"
		fi
	fi
done
