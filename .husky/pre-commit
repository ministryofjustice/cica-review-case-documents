# Fail fast so a precommit check failure blocks the commit.
set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
HAS_STAGED_SCSS=0

if printf '%s\n' "$STAGED_FILES" | grep -Eq '\.scss$'; then
	HAS_STAGED_SCSS=1
fi

npm run precommit

# Re-stage only files that were already staged before running the hook.
if [ -n "$STAGED_FILES" ]; then
	printf '%s\n' "$STAGED_FILES" | while IFS= read -r file; do
		if [ -e "$file" ]; then
			git add -- "$file"
		fi
	done
fi

# Keep generated stylesheet in sync only when staged Sass checks are in scope.
if [ "$HAS_STAGED_SCSS" -eq 1 ]; then
	if git ls-files --error-unmatch public/stylesheets/all.css >/dev/null 2>&1; then
		if ! git diff --quiet -- public/stylesheets/all.css; then
			git add -- public/stylesheets/all.css
		fi
	fi
fi
