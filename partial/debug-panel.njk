{# Debug Panel - Overlay showing diagnostic information #}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% if featureFlags and featureFlags.debug %}
<div class="debug-panel" role="region" aria-label="Debug Panel">
  <div class="debug-panel__header">
    <h2 class="debug-panel__title govuk-heading-s">Debug panel</h2>
    <button class="debug-panel__toggle" aria-expanded="true" aria-controls="debug-content" type="button">Hide</button>
  </div>

  <div class="debug-panel__content" id="debug-content">
    {# Request Summary #}
    <section class="debug-panel__section">
      <h3 class="debug-panel__section-title govuk-heading-s">Request Summary</h3>
      <div class="debug-panel__info-grid">
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Correlation ID:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.request.correlationId or 'n/a' }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Status:</span>
          <span class="debug-panel__value">
            {% if debugInfo.request.responseStatus %}
              {{ govukTag({
                text: debugInfo.request.responseStatus,
                classes: 'govuk-tag--blue'
              }) }}
            {% else %}
              pending
            {% endif %}
          </span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Duration:</span>
          <span class="debug-panel__value">{{ debugInfo.request.elapsedMs or 'n/a' }}{% if debugInfo.request.elapsedMs %}ms{% endif %}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Route:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.request.route or 'n/a' }}</span>
        </div>
      </div>
    </section>

    {# Environment & Session #}
    <section class="debug-panel__section">
      <h3 class="debug-panel__section-title govuk-heading-s">Environment & Session</h3>
      <div class="debug-panel__info-grid">
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Environment:</span>
          <span class="debug-panel__value">{{ debugInfo.environment }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">User:</span>
          <span class="debug-panel__value">{{ debugInfo.session.username }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">CRN:</span>
          <span class="debug-panel__value">{{ debugInfo.session.caseReferenceNumber }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Timestamp:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.timestamp }}</span>
        </div>
      </div>
    </section>

    {# Feature Flags #}
    <section class="debug-panel__section">
      <h3 class="debug-panel__section-title govuk-heading-s">Feature Flags</h3>
      <div class="debug-panel__info-grid">
        {% for flag in debugInfo.featureFlags %}
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">{{ flag.name }}:</span>
            <span class="debug-panel__value">
              {% if flag.value == true %}
                {{ govukTag({
                  text: 'On',
                  classes: 'govuk-tag--green'
                }) }}
              {% elif flag.value == false %}
                {{ govukTag({
                  text: 'Off',
                  classes: 'govuk-tag--red'
                }) }}
              {% else %}
                <span class="debug-panel__value--mono">{{ flag.value }}</span>
              {% endif %}
              <span class="debug-panel__source">({{ flag.source }})</span>
            </span>
          </div>
        {% endfor %}
      </div>
      <div class="debug-panel__control-group">
        {{ govukSelect({
          id: "debug-search-type-select",
          name: "type",
          classes: "debug-panel__select govuk-!-font-size-16",
          label: {
            text: "Search type",
            classes: "govuk-label govuk-label--s"
          },
          formGroup: {
            classes: "govuk-!-margin-bottom-0"
          },
          items: [
            {
              value: "hybrid-dates",
              text: "hybrid-dates",
              selected: featureFlags.type == "hybrid-dates"
            },
            {
              value: "hybrid",
              text: "hybrid",
              selected: featureFlags.type == "hybrid"
            },
            {
              value: "keyword-dates",
              text: "keyword-dates",
              selected: featureFlags.type == "keyword-dates"
            },
            {
              value: "keyword",
              text: "keyword",
              selected: featureFlags.type == "keyword"
            },
            {
              value: "semantic",
              text: "semantic",
              selected: featureFlags.type == "semantic"
            }
          ]
        }) }}
      </div>
    </section>

    {# Current Request #}
    <section class="debug-panel__section">
      <h3 class="debug-panel__section-title govuk-heading-s">Current Request</h3>
      <div class="debug-panel__info-grid">
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Method:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.request.method }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Path:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.request.path }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">URL:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.request.url }}</span>
        </div>
        <div class="debug-panel__info-item">
          <span class="debug-panel__label">Started At:</span>
          <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.request.startedAt }}</span>
        </div>
      </div>
      {% if debugInfo.request.query | length > 0 %}
        <details class="govuk-details debug-panel__details" data-module="govuk-details">
          <summary class="govuk-details__summary debug-panel__summary">
            <span class="govuk-details__summary-text">Query Parameters</span>
          </summary>
          <pre class="debug-panel__code">{{ debugInfo.request.query | dump(2) }}</pre>
        </details>
      {% endif %}
    </section>

    {# Search Info (if available) #}
    {% if debugInfo.search.lastQuery or debugInfo.search.lastDSL or debugInfo.search.opensearch %}
      <section class="debug-panel__section">
        <h3 class="debug-panel__section-title govuk-heading-s">Search Info</h3>
        {% if debugInfo.search.lastQuery %}
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Last Query:</span>
            <span class="debug-panel__value">{{ debugInfo.search.lastQuery }}</span>
          </div>
        {% endif %}
        {% if debugInfo.search.executionTime %}
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Execution Time:</span>
            <span class="debug-panel__value">{{ debugInfo.search.executionTime }}ms</span>
          </div>
        {% endif %}
        {% if debugInfo.search.opensearch %}
          <div class="debug-panel__info-grid">
            <div class="debug-panel__info-item">
              <span class="debug-panel__label">OpenSearch Index:</span>
              <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.search.opensearch.index }}</span>
            </div>
            <div class="debug-panel__info-item">
              <span class="debug-panel__label">Query Hash:</span>
              <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.search.opensearch.queryHash }}</span>
            </div>
            <div class="debug-panel__info-item">
              <span class="debug-panel__label">Returned Hits:</span>
              <span class="debug-panel__value">{{ debugInfo.search.opensearch.returnedHits }}</span>
            </div>
            <div class="debug-panel__info-item">
              <span class="debug-panel__label">Total Hits:</span>
              <span class="debug-panel__value">{{ debugInfo.search.opensearch.totalHits }}</span>
            </div>
            {% if debugInfo.search.opensearch.apiDurationMs %}
              <div class="debug-panel__info-item">
                <span class="debug-panel__label">API Duration:</span>
                <span class="debug-panel__value">{{ debugInfo.search.opensearch.apiDurationMs }}ms</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
        {% if debugInfo.search.lastDSL %}
          <details class="govuk-details debug-panel__details" data-module="govuk-details">
            <summary class="govuk-details__summary debug-panel__summary">
              <span class="govuk-details__summary-text">Current DSL Query</span>
            </summary>
            <pre class="debug-panel__code">{{ debugInfo.search.lastDSL | dump(2) }}</pre>
          </details>
        {% endif %}
        {% if debugInfo.search.previousDSLs | length > 0 %}
          <details class="govuk-details debug-panel__details" data-module="govuk-details">
            <summary class="govuk-details__summary debug-panel__summary">
              <span class="govuk-details__summary-text">Previous DSLs ({{ debugInfo.search.previousDSLs | length }})</span>
            </summary>
            <div class="debug-panel__dsl-history">
              {% for dsl in debugInfo.search.previousDSLs %}
                <details class="govuk-details debug-panel__dsl-item" data-module="govuk-details">
                  <summary class="govuk-details__summary debug-panel__dsl-summary">
                    <span class="govuk-details__summary-text">{{ loop.index }}. {{ dsl.timestamp }}</span>
                  </summary>
                  <pre class="debug-panel__code">{{ dsl.query | dump(2) }}</pre>
                </details>
              {% endfor %}
            </div>
          </details>
        {% endif %}
      </section>
    {% endif %}

    {# Document Info (if available) #}
    {% if debugInfo.document.documentId %}
      <section class="debug-panel__section">
        <h3 class="debug-panel__section-title govuk-heading-s">Document Info</h3>
        <div class="debug-panel__info-grid">
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Document ID:</span>
            <span class="debug-panel__value debug-panel__value--mono">{{ debugInfo.document.documentId }}</span>
          </div>
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Page Number:</span>
            <span class="debug-panel__value">{{ debugInfo.document.pageNumber }}</span>
          </div>
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Highlights:</span>
            <span class="debug-panel__value">{{ debugInfo.document.highlightsCount }}</span>
          </div>
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Aligned:</span>
            <span class="debug-panel__value">
              {% if debugInfo.document.chunksAligned %}
                {{ govukTag({
                  text: 'Yes',
                  classes: 'govuk-tag--green'
                }) }}
              {% else %}
                {{ govukTag({
                  text: 'No',
                  classes: 'govuk-tag--red'
                }) }}
              {% endif %}
            </span>
          </div>
        </div>
      </section>
    {% endif %}

    {# API Calls #}
    {% if debugInfo.apiCalls | length > 0 %}
      <section class="debug-panel__section">
        <h3 class="debug-panel__section-title govuk-heading-s">API Calls ({{ debugInfo.apiCalls | length }})</h3>
        <label class="debug-panel__control" for="debug-api-failures-only">
          <input id="debug-api-failures-only" type="checkbox" />
          Show failures only
        </label>
        <div class="debug-panel__api-calls">
          {% for call in debugInfo.apiCalls | reverse %}
            <div class="debug-panel__api-call" data-failed="{{ call.isError }}">
              <span class="debug-panel__api-method">{{ call.method }}</span>
              <span class="debug-panel__api-path">{{ call.path }}</span>
              <span class="debug-panel__api-status" data-status="{{ call.statusCode }}">{{ call.statusCode }}</span>
              <span class="debug-panel__api-time">{{ call.durationMs or 'n/a' }}{% if call.durationMs %}ms{% endif %}</span>
              {% if call.errorMessage %}
                <span class="debug-panel__api-error">{{ call.errorMessage }}</span>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# Redirects (if any) #}
    {% if debugInfo.redirects | length > 0 %}
      <section class="debug-panel__section">
        <h3 class="debug-panel__section-title govuk-heading-s">Redirects ({{ debugInfo.redirects | length }})</h3>
        <div class="debug-panel__redirects">
          {% for redirect in debugInfo.redirects %}
            <div class="debug-panel__redirect-item">
              <span class="debug-panel__redirect-reason">{{ redirect.reason }}</span>
              <span class="debug-panel__redirect-time">{{ redirect.timestamp }}</span>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# Validation Errors (if any) #}
    {% if debugInfo.validationErrors | length > 0 %}
      <section class="debug-panel__section">
        <h3 class="debug-panel__section-title govuk-heading-s">Validation Errors ({{ debugInfo.validationErrors | length }})</h3>
        <div class="debug-panel__validation-errors">
          {% for error in debugInfo.validationErrors %}
            <div class="debug-panel__error-item">
              <span class="debug-panel__error-field">{{ error.field }}</span>
              <span class="debug-panel__error-message">{{ error.message }}</span>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# OpenSearch Metadata (if search happened) #}
    {% if debugInfo.search.opensearch and debugInfo.search.opensearch.totalShards %}
      <section class="debug-panel__section">
        <h3 class="debug-panel__section-title govuk-heading-s">OpenSearch Metadata</h3>
        <div class="debug-panel__info-grid">
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Total Shards:</span>
            <span class="debug-panel__value">{{ debugInfo.search.opensearch.totalShards }}</span>
          </div>
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Failed Shards:</span>
            <span class="debug-panel__value">
              {% if debugInfo.search.opensearch.failedShards %}
                {{ govukTag({
                  text: debugInfo.search.opensearch.failedShards,
                  classes: 'govuk-tag--red'
                }) }}
              {% else %}
                0
              {% endif %}
            </span>
          </div>
          <div class="debug-panel__info-item">
            <span class="debug-panel__label">Timed Out:</span>
            <span class="debug-panel__value">
              {% if debugInfo.search.opensearch.timedOut %}
                {{ govukTag({
                  text: 'Yes',
                  classes: 'govuk-tag--red'
                }) }}
              {% else %}
                {{ govukTag({
                  text: 'No',
                  classes: 'govuk-tag--green'
                }) }}
              {% endif %}
            </span>
          </div>
        </div>
      </section>
    {% endif %}

    {# Copy Snapshot #}
    <div class="debug-panel__footer">
      <button id="debug-copy-snapshot" class="debug-panel__copy-btn" type="button" title="Copy debug info as JSON">📋 Copy Snapshot</button>
    </div>
  </div>
  <script id="debug-panel-data" type="application/json">{{ debugInfo | dump | safe }}</script>
</div>
{% endif %}
